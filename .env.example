# Railway auto-sets this when you add PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/railway?schema=public"

# Session secret for cookie signing (generate a random string)
SESSION_SECRET="change-me-to-a-random-secret"

# WhatsApp session directory (set to your Railway volume mount path)
# In Railway: set to "/app/session" (must match your volume mount point)
# Locally: defaults to ".whatsapp-auth" in project root
WHATSAPP_AUTH_DIR="/app/session"
